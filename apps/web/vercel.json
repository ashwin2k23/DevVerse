{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "pnpm --filter web build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/socket/:path*",
      "destination": "https://your-api.up.railway.app/api/socket/:path*"
    }
  ]
}

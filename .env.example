# ═══════════════════════════════════════════════════════════════
# DevVerse — Environment Variables Reference
# ═══════════════════════════════════════════════════════════════
# Copy the relevant sections to each app's .env file:
#   apps/api/.env       — for the backend API (Express)
#   apps/web/.env.local — for the frontend (Next.js)
# ───────────────────────────────────────────────────────────────

# ─── CLERK (Authentication) ─────────────────────────────────────
# Get from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─── DATABASE ───────────────────────────────────────────────────
# LOCAL DEVELOPMENT (SQLite file):
DATABASE_URL=file:./dev.db

# PRODUCTION (Turso — free at https://turso.tech):
# DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your_turso_token_here

# ─── BACKEND API ────────────────────────────────────────────────
# Development:
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
API_PORT=4000
PORT=4000

# Production (replace with your Railway URL):
# NEXT_PUBLIC_API_URL=https://your-api.up.railway.app
# NEXT_PUBLIC_SOCKET_URL=https://your-api.up.railway.app

# ─── CLOUDINARY (Image Uploads) ─────────────────────────────────
# Get from: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ─── SERVER ─────────────────────────────────────────────────────
NODE_ENV=development
CLIENT_URL=http://localhost:3000
# Production: CLIENT_URL=https://your-app.vercel.app
